# ============================================================
# SkillGraph AI – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Application ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://skillgraph_user:skillgraph_password@localhost:5432/skillgraph_db?schema=public

# ─── JWT ─────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-characters-long-here
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Security ─────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────
# Window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────────
# Options: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
